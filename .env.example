# Local development environment.
# Copy this file to `.env` and adjust as needed.
# Real production secrets live in Vault / 1Password Connect — never here.

# ---------- Postgres (application database) ----------
# Two roles per database, per RES-83:
#   POSTGRES_USER / DATABASE_ADMIN_URL — schema owner; runs migrations only.
#   resto_app    / DATABASE_URL        — runtime; NOSUPERUSER NOBYPASSRLS.
# The dev stack provisions resto_app from infra/docker/postgres/init/.
POSTGRES_USER=resto
POSTGRES_PASSWORD=resto_dev_password
POSTGRES_DB=resto
POSTGRES_PORT=5432
DATABASE_ADMIN_URL=postgres://resto:resto_dev_password@localhost:5432/resto
DATABASE_URL=postgres://resto_app:resto_app_dev_password@localhost:5432/resto

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- NATS JetStream ----------
NATS_PORT=4222
NATS_HTTP_PORT=8222
NATS_URL=nats://localhost:4222
NATS_STREAM=RESTO_EVENTS

# ---------- Keycloak ----------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/resto
KEYCLOAK_CLIENT_ID=resto-api
KEYCLOAK_CLIENT_SECRET=

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=resto-dev
# Match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above for dev. In production
# these are per-bucket IAM credentials from Vault / 1Password Connect.
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_password

# ---------- MailHog (SMTP catcher) ----------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025

# ---------- Jaeger / OpenTelemetry ----------
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=resto-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# ---------- Application ----------
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3000
ADMIN_PORT=3001
WEBSITE_PORT=3002
QR_MENU_PORT=3003
LANDING_PORT=3004
