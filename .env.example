# Local development environment.
# Copy this file to `.env` and adjust as needed.
# Real production secrets live in Vault / 1Password Connect — never here.

# ---------- Postgres (application database) ----------
# Two roles per database, per RES-83:
#   POSTGRES_USER / DATABASE_ADMIN_URL — schema owner; runs migrations only.
#   resto_app    / DATABASE_URL        — runtime; NOSUPERUSER NOBYPASSRLS.
# The dev stack provisions resto_app from infra/docker/postgres/init/.
POSTGRES_USER=resto
POSTGRES_PASSWORD=resto_dev_password
POSTGRES_DB=resto
POSTGRES_PORT=5432
DATABASE_ADMIN_URL=postgres://resto:resto_dev_password@localhost:5432/resto
DATABASE_URL=postgres://resto_app:resto_app_dev_password@localhost:5432/resto

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- NATS JetStream ----------
NATS_PORT=4222
NATS_HTTP_PORT=8222
NATS_URL=nats://localhost:4222
NATS_STREAM=RESTO_EVENTS

# ---------- Internal API auth ----------
# Shared secret guarding `/internal/v1/*` until the admin UI lands in
# MVP-2 (see ADR-0012). The seed CLI must use the same value.
INTERNAL_API_TOKEN=internal_dev_token_change_me

# ---------- Better Auth (identity, MVP-2 — ADR-0013) ----------
# All four required outside NODE_ENV=development; rotate per environment
# via Vault / 1Password Connect in staging and prod.
#
# 32+ char secret used to sign session cookies and tokens. Generate with
# `openssl rand -base64 48` for staging/prod.
BETTER_AUTH_SECRET=local_dev_secret_replace_me_with_a_real_32_char_value
# Public base URL of the api (cookie scope + email-link generation).
BETTER_AUTH_BASE_URL=http://localhost:3000
# Connection string for BA's drizzle client. Connects under `resto_auth`
# (BYPASSRLS) — distinct from DATABASE_URL (`resto_app` NOBYPASSRLS).
# Seeded by infra/docker/postgres/init/ alongside the resto_app role.
BETTER_AUTH_DATABASE_URL=postgres://resto_auth:auth_password_dev@localhost:5432/resto
# Cookie domain. Leave unset in dev so cookies bind host-only; set to
# `.resto.app` in production for cross-subdomain session sharing
# (admin.resto.app ↔ api.resto.app).
# AUTH_COOKIE_DOMAIN=
# Public URL of the admin web app — used as link target in invitation
# and password-reset emails.
ADMIN_WEB_URL=http://localhost:3001

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=resto-dev
# Match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above for dev. In production
# these are per-bucket IAM credentials from Vault / 1Password Connect.
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_password

# ---------- MailHog (SMTP catcher) ----------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025

# ---------- Jaeger / OpenTelemetry ----------
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=resto-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# ---------- Application ----------
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3000
ADMIN_PORT=3001
WEBSITE_PORT=3002
QR_MENU_PORT=3003
LANDING_PORT=3004
