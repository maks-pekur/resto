{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "qr-menu",
  "projectType": "application",
  "sourceRoot": "apps/qr-menu/src",
  "tags": ["scope:qr-menu", "type:app", "layer:ui"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "apps/qr-menu"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "apps/qr-menu"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/qr-menu"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "apps/qr-menu"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite",
        "cwd": "apps/qr-menu"
      }
    }
  }
}
