{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "api",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "tags": ["scope:api", "type:app", "layer:application"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "apps/api"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "apps/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run test/unit",
        "cwd": "apps/api"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run test/e2e",
        "cwd": "apps/api"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node build.mjs",
        "cwd": "apps/api"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "openapi:emit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm openapi:emit",
        "cwd": "apps/api"
      },
      "outputs": ["{workspaceRoot}/docs/api/openapi.yaml"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch src/main.ts",
        "cwd": "apps/api"
      }
    }
  }
}
