{
  "extends": "@resto/config-typescript/node.json",
  "compilerOptions": {
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts", "eslint.config.mjs"],
  "exclude": ["node_modules", "dist"]
}
