{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "seed-cli",
  "projectType": "application",
  "sourceRoot": "tools/scripts/seed",
  "tags": ["scope:tools", "type:cli"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "tools/scripts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "tools/scripts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "tools/scripts"
      }
    }
  }
}
