{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "db",
  "projectType": "library",
  "sourceRoot": "packages/db/src",
  "tags": ["scope:shared", "type:lib", "layer:infrastructure"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "packages/db"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "packages/db"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/db"
      }
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm db:generate",
        "cwd": "packages/db"
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm db:migrate",
        "cwd": "packages/db"
      }
    },
    "db:reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm db:reset",
        "cwd": "packages/db"
      }
    }
  }
}
