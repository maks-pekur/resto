{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Resto NestJS",
  "extends": "./node.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "outDir": "./dist"
  }
}
